#!/usr/bin/env bash
# Shortcuts cheatsheet - sve prečice sortirane po tipu

RED='\033[38;2;192;57;43m'
GRAY='\033[38;2;150;150;160m'
WHITE='\033[38;2;245;245;245m'
DIM='\033[38;2;100;100;110m'
BOLD='\033[1m'
RESET='\033[0m'

key() { printf "  ${RED}${BOLD}%-20s${RESET} ${WHITE}%s${RESET}\n" "$1" "$2"; }
header() { printf "\n${GRAY}${BOLD}▍ %s${RESET}\n" "$1"; }

printf "${RED}${BOLD}"
cat << 'EOF'
   ╔═══════════════════════════════╗
   ║   SHORTCUTS  —  Stardew        ║
   ╚═══════════════════════════════╝
EOF
printf "${RESET}"

header "PROGRAMI (Meta + slovo)"
key "Meta + Return" "Ghostty (terminal)"
key "Meta + E" "Yazi (file manager)"
key "Meta + Z" "Zed (editor)"
key "Meta + B" "Zen Browser"
key "Meta + S" "Steam"
key "Meta + L" "Lutris"
key "Meta + G" "Heroic (Epic/GOG)"
key "Meta + O" "Obsidian"
key "Meta + D" "Discord (vesktop)"
key "Meta + V" "LibreOffice"
key "Meta + C" "Blender"

header "NAVIGACIJA / PROZORI"
key "Meta + strelice" "Fokus na prozor (u pravcu)"
key "Meta + Q" "Zatvori prozor"
key "Meta + Tab" "Overview (svi prozori)"
key "Meta + Space" "KRunner (pokretač)"
key "Meta + Escape" "Zaključaj ekran"
key "Ctrl + F1-F4" "Virtuelni desktop 1-4"

header "TILING (Krohnkite)"
key "Meta+Shift+strelice" "Pomeri prozor"
key "Meta+Ctrl+strelice" "Resize prozor"
key "Meta + Shift + T" "Tile layout"
key "Meta + Shift + M" "Monocle (fullscreen)"
key "Meta + Shift + F" "Float (za igre!)"
key "Meta + Shift + Space" "Sledeći layout"
key "Meta + Shift + Return" "Postavi kao master"
key "Meta + Shift + R" "Rotate"

header "YAZI (unutar file managera)"
key "j / k" "Gore / dole"
key "h / l" "Nazad / uđi ili otvori"
key "y / x / p" "Kopiraj / iseci / nalepi"
key "d / D" "U kantu / trajno obriši"
key "a / r" "Napravi / preimenuj"
key "f" "Skoči na karakter"
key "z" "Fuzzy find fajl (fzf)"
key "Z" "Skoči na dir preko istorije (zoxide)"
key "cm" "Promeni permisije (chmod)"
key "M" "Mount meni (USB)"
key "C" "Kompresuj u arhivu"
key "/ ili s" "Pretraga"
key "Space" "Selektuj fajl"
key "q" "Izađi (sa 'y' menja folder)"

header "TERMINAL (alati & aliasi)"
key "ls / ll / la" "Lep listing (eza: ikone, git)"
key "z <dir>" "Skok na direktorijum (zoxide)"
key "zi" "Interaktivni izbor dir (zoxide)"
key "y" "Yazi (na izlazu menja folder)"
key "fd <ime>" "Brzo traženje fajlova"
key "rg <tekst>" "Pretraga po sadržaju (ripgrep)"
key "fzf" "Fuzzy finder (pipe u njega)"
key "ncdu" "Šta troši disk (TUI)"
key "btop" "Monitor resursa (CPU/RAM)"
key "yt-dlp <url>" "Download video (+ffmpeg merge)"
key "ffmpeg" "Konverzija/obrada medija"

header "TMUX (multiplexer)"
printf "  ${DIM}Prefiks = Ctrl+a. Pritisni Ctrl+a, PUSTI, pa tek onda taster.${RESET}\n"
printf "  ${DIM}To su DVA odvojena poteza, nije kombinacija (i nije Ctrl+c).${RESET}\n"
key "tmux" "Pokreni novu sesiju"
key "tmux a" "Prikači se na postojeću sesiju"
key "Ctrl+a c" "Novi prozor (window)"
key "Ctrl+a n / p" "Sledeći / prethodni prozor"
key "Ctrl+a 1-9" "Skoči na prozor po broju"
key "Ctrl+a %" "Split panel vertikalno (levo/desno)"
key "Ctrl+a \"" "Split panel horizontalno (gore/dole)"
key "Ctrl+a strelice" "Fokus na panel (u pravcu)"
key "Ctrl+a z" "Zoom panel na ceo ekran (toggle)"
key "Ctrl+a x" "Zatvori panel"
key "Ctrl+a d" "Detach (sesija ostaje živa)"
key "Ctrl+a [" "Scroll / copy mode (q za izlaz)"
key "Ctrl+a ?" "Prikaži sve tmux prečice"
key "Miš" "Klik / scroll / drag radi (mouse on)"

header "NIX (održavanje)"
key "rebuild" "Build + commit + push (auto host)"
key "update" "nix flake update (novi paketi)"

header "SISTEM"
key "Print" "Screenshot (Spectacle)"
key "shortcuts" "Prikaži ovaj meni"

printf "\n${DIM}Tip: 'shortcuts' bilo kad da vidiš prečice.${RESET}\n\n"
