# secrets.yaml.example — ŠABLON (NIJE šifrovan, ne koristi se direktno).
#
# Kako da napraviš pravi šifrovani secrets.yaml:
#   1. Napravi age ključeve i upiši javne delove u .sops.yaml (REPLACE markeri).
#   2. Napravi host ključ na mašini: /var/lib/sops-nix/key.txt
#   3. `nix shell nixpkgs#sops -c sops secrets.yaml`  # otvara editor
#        unesi npr:  example_secret: neka-tajna-vrednost
#   4. Sačuvaj — sops ga šifruje. ŠIFROVANI secrets.yaml je BEZBEDAN za commit.
#
# Struktura koju modules/system/secrets.nix očekuje:
example_secret: "zameni-me-pa-sifruj-sa-sops"

# Lozinke drže HEŠ (izlaz `mkpasswd -m sha-512`), NIKAD plaintext.
# Generiši: `nix shell nixpkgs#mkpasswd -c mkpasswd -m sha-512`
# whitewolf postoji na svim hostovima; lizzywizzy samo na Stardew/SolidSnake.
whitewolf-password: "$6$ZAMENI_ME$sha512-heš-ovde"
lizzywizzy-password: "$6$ZAMENI_ME$sha512-heš-ovde"

# restic (Stardew backup):
# restic-repo-password: proizvoljna jaka lozinka za enkripciju restic repozitorijuma.
# restic-b2-credentials: environmentFile format (KLJUC=vrednost po liniji).
restic-repo-password: "zameni-jakom-lozinkom-pa-sifruj"
restic-b2-credentials: |
  B2_ACCOUNT_ID=zameni
  B2_ACCOUNT_KEY=zameni
